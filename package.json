{
  "name": "@wassist/sdk",
  "version": "0.1.0",
  "description": "Wassist SDK – the TypeScript client for the Wassist API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "push": "cd ../../ && git subtree push --prefix=packages/sdk git@github.com:Wassist/sdk.git main",
    "publish": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wassist/sdk.git"
  },
  "homepage": "https://github.com/wassist/sdk#readme",
  "bugs": {
    "url": "https://github.com/wassist/sdk/issues"
  },
  "keywords": [
    "whatsapp",
    "wassist",
    "sdk",
    "api",
    "whatsapp-api",
    "messaging",
    "chatbot",
    "ai-agent"
  ],
  "author": "Wassist",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
